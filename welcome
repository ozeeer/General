inite; animation-delay: 0s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 26%; bottom: -30px; width: 6px; height: 6px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 17s linear infinite; animation-delay: 2.5s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 40%; bottom: -30px; width: 8px; height: 8px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 11s linear infinite; animation-delay: 5s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 57%; bottom: -30px; width: 5px; height: 5px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 15s linear infinite; animation-delay: 1.2s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 70%; bottom: -30px; width: 11px; height: 11px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 18s linear infinite; animation-delay: 3.8s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 83%; bottom: -30px; width: 7px; height: 7px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 14s linear infinite; animation-delay: 6.5s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 48%; bottom: -30px; width: 4px; height: 4px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 19s linear infinite; animation-delay: 8s; pointer-events: none;\"><\u002Fdiv>\n  <div style=\"position: absolute; left: 91%; bottom: -30px; width: 6px; height: 6px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--accent,#27c2b6) 90%, white), var(--accent,#27c2b6)); filter: blur(1px); opacity: 0; animation: floatUp 16s linear infinite; animation-delay: 4.4s; pointer-events: none;\"><\u002Fdiv>\n\n  <!-- reveal group (remounts on replay) -->\n  <div key=\"{{ runId }}\" style=\"position: relative; display: inline-block; line-height: 0; z-index: 2;\">\n\n    <img src=\"30f690c5-296b-4f59-a6d3-c11486c30a88\" alt=\"Ozbolat Lab\" draggable=\"false\" style=\"display: block; width: min(72vw, 880px); height: auto; aspect-ratio: 1815 / 426; clip-path: inset(100% 0% 0% 0%); animation-name: var(--logo-anim, printOnce); animation-duration: var(--rev-dur, 4s); animation-timing-function: cubic-bezier(0.66, 0, 0.34, 1); animation-iteration-count: var(--iter, 1); animation-fill-mode: both;\">\n\n    <!-- print-head scan line -->\n    <sc-if value=\"{{ isPrint }}\" hint-placeholder-val=\"{{ true }}\">\n      <div style=\"position: absolute; left: -3%; right: -3%; top: 100%; transform: translateY(-50%); animation-name: var(--scan-anim, scanOnce); animation-duration: var(--rev-dur, 4s); animation-timing-function: cubic-bezier(0.66, 0, 0.34, 1); animation-iteration-count: var(--iter, 1); animation-fill-mode: both; pointer-events: none;\">\n        <div style=\"position: absolute; left: 0; right: 0; top: 50%; height: 56px; transform: translateY(-50%); background: linear-gradient(to top, color-mix(in srgb, var(--accent,#27c2b6) 26%, transparent), transparent 80%); filter: blur(6px);\"><\u002Fdiv>\n        <div style=\"position: absolute; left: 0; right: 0; top: 50%; height: 2px; transform: translateY(-50%); background: linear-gradient(90deg, transparent, var(--accent,#27c2b6) 18%, #eafffb 50%, var(--accent,#27c2b6) 82%, transparent); box-shadow: 0 0 16px 1px var(--accent,#27c2b6), 0 0 36px 3px color-mix(in srgb, var(--accent,#27c2b6) 55%, transparent);\"><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fsc-if>\n\n  <\u002Fdiv>\n\n  <!-- controls -->\n  <button sc-camel-on-click=\"{{ replay }}\" title=\"Replay\" style=\"position: absolute; right: 22px; bottom: 20px; z-index: 5; display: inline-flex; align-items: center; gap: 8px; padding: 9px 16px 9px 13px; border: 1px solid color-mix(in srgb, var(--accent,#27c2b6) 45%, transparent); border-radius: 999px; background: rgba(8, 24, 40, 0.55); backdrop-filter: blur(6px); color: #d6f5f1; font: 600 12px/1 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer;\">\n    <span style=\"font-size: 14px; line-height: 1;\">↻<\u002Fspan> Replay\n  <\u002Fbutton>\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;$preview&quot;:{&quot;width&quot;:1280,&quot;height&quot;:720},&quot;revealStyle&quot;:{&quot;editor&quot;:&quot;enum&quot;,&quot;options&quot;:[&quot;Print build&quot;,&quot;Fade &amp; scale&quot;],&quot;default&quot;:&quot;Print build&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;loop&quot;:{&quot;editor&quot;:&quot;boolean&quot;,&quot;default&quot;:false,&quot;tsType&quot;:&quot;boolean&quot;},&quot;duration&quot;:{&quot;editor&quot;:&quot;float&quot;,&quot;default&quot;:4,&quot;min&quot;:2,&quot;max&quot;:10,&quot;step&quot;:0.5,&quot;tsType&quot;:&quot;number&quot;},&quot;accent&quot;:{&quot;editor&quot;:&quot;color&quot;,&quot;default&quot;:&quot;#27c2b6&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;redirectUrl&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;/index.html&quot;,&quot;tsType&quot;:&quot;string&quot;,&quot;section&quot;:&quot;Same-site reveal (path to your homepage, e.g. /index.html)&quot;}}\">\nclass Component extends DCLogic {\n  state = { runId: 0 };\n  _redirectTimer = null;\n\n  componentDidMount() {\n    this._scheduleRedirect();\n  }\n  componentDidUpdate(prevProps, prevState) {\n    if (prevState.runId !== this.state.runId) this._scheduleRedirect();\n  }\n  componentWillUnmount() {\n    if (this._redirectTimer) clearTimeout(this._redirectTimer);\n  }\n  _scheduleRedirect() {\n    if (this._redirectTimer) clearTimeout(this._redirectTimer);\n    const p = this.props || {};\n    const url = p.redirectUrl;\n    if (!url) return;\n    const dur = p.duration ?? 4;\n    this._redirectTimer = setTimeout(() => {\n      this.setState({ revealed: true });\n    }, dur * 1000 + 300);\n  }\n\n  renderVals() {\n    const p = this.props || {};\n    const loop = p.loop ?? true;\n    const style = p.revealStyle ?? 'Print build';\n    const dur = p.duration ?? 4;\n    const accent = p.accent ?? '#27c2b6';\n    const isPrint = style === 'Print build';\n\n    const logoAnim = (isPrint ? 'print' : 'fade') + (loop ? 'Loop' : 'Once');\n    const scanAnim = loop ? 'scanLoop' : 'scanOnce';\n    const iter = loop ? 'infinite' : '1';\n\n    const stageRef = (el) => {\n      if (!el) return;\n      el.style.setProperty('--rev-dur', dur + 's');\n      el.style.setProperty('--accent', accent);\n      el.style.setProperty('--logo-anim', logoAnim);\n      el.style.setProperty('--scan-anim', scanAnim);\n      el.style.setProperty('--iter', iter);\n    };\n\n    return {\n      runId: this.state.runId,\n      isPrint,\n      showSheen: !loop,\n      stageRef,\n      hasRedirect: !!p.redirectUrl,\n      revealed: this.state.revealed ? 1 : 0,\n      pageUrl: p.redirectUrl,\n      stageOpacity: this.state.revealed ? 0 : 1,\n      stagePointerEvents: this.state.revealed ? 'none' : 'auto',\n      replay: () => this.setState((s) => ({ runId: s.runId + 1, revealed: false })),\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
